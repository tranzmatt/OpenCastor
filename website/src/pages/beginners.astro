                  d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
              </svg>
              View on GitHub
            </a>
            <a href="https://github.com/craigm26/OpenCastor/issues" class="community-link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
              </svg>
              Ask a question
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- ======== CTA ======== -->
    <section class="cta-section">
      <h2 class="reveal">Ready? Let's build something. 🚀</h2>
      <p class="reveal reveal-d1">One command. Two minutes. Your robot, thinking with AI.</p>
      <div class="install-block reveal reveal-d2" style="margin:0 auto 32px; max-width:480px;">
        <code id="install-cmd-beginner">curl -fsSL opencastor.com/install | bash</code>
        <button onclick="copyInstallBeginner()">Copy</button>
      </div>
      <div class="hero-actions reveal reveal-d3">
        <a href="#install" class="btn btn-primary btn-lg">
          View setup steps
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
        <a href="/hardware" class="btn btn-secondary btn-lg">Browse hardware</a>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div class="footer-brand">
          <a href="/" class="nav-logo">
      <div class="nav-logo-img"></div>
      <span>OpenCastor</span>
    </a>
          <p>The universal runtime for embodied AI.</p>
        </div>
        <div class="footer-col">
          <h4>Product</h4><a href="/docs">Documentation</a><a href="/hardware">Hardware</a><a
            href="https://rcan.dev/spec/">RCAN Spec</a><a href="https://pypi.org/project/opencastor/">PyPI</a>
        </div>
        <div class="footer-col">
          <h4>Resources</h4><a href="/beginners">Beginner Guide</a><a
            href="https://github.com/craigm26/OpenCastor">GitHub</a><a
            href="https://github.com/craigm26/OpenCastor/issues">Issues</a><a
            href="https://discord.gg/jMjA8B26Bq">Discord</a>
        </div>
        <div class="footer-col">
          <h4>Company</h4><a href="/hub">Hub</a><a href="/about">About</a><a
            href="mailto:hello@opencastor.com">Contact</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2025-2026 Craig Merry. Apache 2.0 License.</p>
