        Star on GitHub
      </a>
    </div>

    <div class="install-block reveal-d4">
      <code id="install-cmd">curl -sL opencastor.com/install | bash</code>
      <button onclick="copyInstall()">Copy</button>
    </div>

    <div class="hero-links reveal-d5">
      <a href="https://pypi.org/project/opencastor/">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9.585 11.692h4.328s2.432.039 2.432-2.35V5.391S16.714 3 11.936 3C7.362 3 7.647 4.983 7.647 4.983l.006 2.055h4.363v.617H5.92S3 7.28 3 11.874s2.547 4.456 2.547 4.456h1.521v-2.143s-.083-2.547 2.508-2.547l-.001.052zm-.282-4.444a.812.812 0 110-1.624.812.812 0 010 1.624z"/><path d="M14.415 12.308h-4.328s-2.432-.039-2.432 2.35v3.951S7.286 21 12.064 21c4.574 0 4.289-1.983 4.289-1.983l-.006-2.055h-4.363v-.617h6.096S21 16.72 21 12.126s-2.547-4.456-2.547-4.456h-1.521v2.143s.083 2.547-2.508 2.547l.001-.052zm.282 4.444a.812.812 0 110 1.624.812.812 0 010-1.624z"/></svg>
        PyPI
