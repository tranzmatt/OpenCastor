---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="OpenCastor — The Universal Runtime for Embodied AI"
  description="Give any robot a brain. Apple Foundation Models + 12+ AI providers, stack-aware setup, and a $0 primary brain. Open source, Apache 2.0."
  ogUrl="https://opencastor.com"
>

<main>

<!-- ======== HERO ======== -->
<section class="hero">
  <div class="hero-card reveal">
    <div class="hero-status-bar">
      <div class="badge status-live">
        <span class="dot"></span>
        Runtime: Active
      </div>
      <div class="badge status-version">
        v2026.3.21.1
      </div>
    </div>

    <!-- Phase 8: Prominent Brand Identifier -->
    <div class="hero-brand-logo reveal">
      <img src="/assets/icon-128.png" alt="OpenCastor Icon" width="64" height="64" />
      <span class="brand-text">OpenCastor</span>
    </div>

    <h1 class="hero-title reveal-d1">
      The Universal Runtime for<br><span class="gradient-text">Embodied AI.</span>
    </h1>

    <p class="hero-sub reveal-d2">
      Give any robot a brain. Semantic perception with local embeddings, 13+ AI providers,<br>
      HLabs ACB · LiDAR · IMU · depth cameras · reactive obstacle avoidance. One config file. Zero lock-in.
    </p>

    <div class="hero-actions reveal-d3">
      <a href="https://docs.opencastor.com" class="btn btn-primary btn-lg pulse-btn">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"></path></svg>
        Connect to Robot
      </a>
      <a href="https://github.com/craigm26/OpenCastor" class="btn btn-secondary btn-lg">
