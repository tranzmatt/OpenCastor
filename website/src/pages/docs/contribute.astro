    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .mermaid { padding: 24px; overflow-x: auto; }
  .arch-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .arch-table th {
    text-align: left;
    padding: 8px 12px;
