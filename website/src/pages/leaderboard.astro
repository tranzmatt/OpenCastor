---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Fleet Research Leaderboard — OpenCastor"
  description="Robots that contribute idle compute to OpenCastor harness optimization earn their place here. Each evaluation improves AI decision-making across the fleet."
  ogUrl="https://opencastor.com/leaderboard"
>

<main>

<!-- ======== HERO ======== -->
<section class="lb-hero">
  <div class="container">
    <div class="lb-hero-inner reveal">
      <div class="lb-badge">
        <span class="dot"></span>
        Live Rankings
      </div>
      <h1 class="lb-title">Fleet Research Leaderboard</h1>
      <p class="lb-sub">
        Robots contribute idle compute to OpenCastor harness optimization. Each evaluation takes ~1s
        and helps improve AI decision-making across the fleet. The reward is being on the leaderboard.
      </p>
      <div class="lb-actions">
        <a href="/docs/contribute" class="btn btn-primary">Enable on your robot</a>
        <a href="/docs/contribute#how-it-works" class="btn btn-secondary">How it works</a>
      </div>
    </div>
  </div>
</section>

<!-- ======== TIERS ======== -->
<section class="lb-tiers">
  <div class="container">

    <!-- pi5-hailo8l -->
    <div class="lb-tier-card reveal" id="tier-pi5-hailo8l">
      <div class="lb-tier-header">
        <div class="lb-tier-name">
          <span class="lb-tier-icon">&#9679;</span>
          Pi 5 + Hailo-8L
        </div>
        <span class="lb-tier-badge">NPU Tier</span>
      </div>
      <div class="lb-table-wrap">
        <table class="lb-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Robot (RRN)</th>
              <th>Score</th>
              <th>Evals</th>
              <th>Last Active</th>
            </tr>
          </thead>
          <tbody id="tbody-pi5-hailo8l">
            <tr class="lb-loading"><td colspan="5">Loading&#8230;</td></tr>
          </tbody>
        </table>
        <div class="lb-empty" id="empty-pi5-hailo8l" style="display:none">
          No contributions yet &mdash; <a href="/docs/contribute">enable castor contribute on your robot</a>
        </div>
      </div>
    </div>

    <!-- pi5-8gb -->
    <div class="lb-tier-card reveal" id="tier-pi5-8gb">
      <div class="lb-tier-header">
        <div class="lb-tier-name">
          <span class="lb-tier-icon">&#9679;</span>
          Pi 5 8GB
        </div>
        <span class="lb-tier-badge">SBC Tier</span>
      </div>
      <div class="lb-table-wrap">
        <table class="lb-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Robot (RRN)</th>
              <th>Score</th>
              <th>Evals</th>
              <th>Last Active</th>
            </tr>
          </thead>
          <tbody id="tbody-pi5-8gb">
            <tr class="lb-loading"><td colspan="5">Loading&#8230;</td></tr>
          </tbody>
        </table>
        <div class="lb-empty" id="empty-pi5-8gb" style="display:none">
          No contributions yet &mdash; <a href="/docs/contribute">enable castor contribute on your robot</a>
        </div>
      </div>
    </div>

    <!-- pi4-8gb -->
    <div class="lb-tier-card reveal" id="tier-pi4-8gb">
      <div class="lb-tier-header">
        <div class="lb-tier-name">
          <span class="lb-tier-icon">&#9679;</span>
          Pi 4 8GB
        </div>
        <span class="lb-tier-badge">SBC Tier</span>
      </div>
      <div class="lb-table-wrap">
        <table class="lb-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Robot (RRN)</th>
              <th>Score</th>
              <th>Evals</th>
              <th>Last Active</th>
            </tr>
          </thead>
          <tbody id="tbody-pi4-8gb">
            <tr class="lb-loading"><td colspan="5">Loading&#8230;</td></tr>
          </tbody>
        </table>
        <div class="lb-empty" id="empty-pi4-8gb" style="display:none">
          No contributions yet &mdash; <a href="/docs/contribute">enable castor contribute on your robot</a>
        </div>
      </div>
    </div>

    <!-- server -->
    <div class="lb-tier-card reveal" id="tier-server">
      <div class="lb-tier-header">
        <div class="lb-tier-name">
          <span class="lb-tier-icon">&#9679;</span>
          Server
        </div>
        <span class="lb-tier-badge">Server Tier</span>
      </div>
      <div class="lb-table-wrap">
        <table class="lb-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Robot (RRN)</th>
              <th>Score</th>
              <th>Evals</th>
              <th>Last Active</th>
            </tr>
          </thead>
          <tbody id="tbody-server">
            <tr class="lb-loading"><td colspan="5">Loading&#8230;</td></tr>
          </tbody>
        </table>
        <div class="lb-empty" id="empty-server" style="display:none">
          No contributions yet &mdash; <a href="/docs/contribute">enable castor contribute on your robot</a>
        </div>
      </div>
    </div>

    <!-- waveshare-alpha -->
    <div class="lb-tier-card reveal" id="tier-waveshare-alpha">
      <div class="lb-tier-header">
        <div class="lb-tier-name">
          <span class="lb-tier-icon">&#9679;</span>
          Waveshare Alpha
        </div>
        <span class="lb-tier-badge">Robot Tier</span>
      </div>
      <div class="lb-table-wrap">
        <table class="lb-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Robot (RRN)</th>
              <th>Score</th>
              <th>Evals</th>
              <th>Last Active</th>
            </tr>
          </thead>
          <tbody id="tbody-waveshare-alpha">
            <tr class="lb-loading"><td colspan="5">Loading&#8230;</td></tr>
          </tbody>
        </table>
        <div class="lb-empty" id="empty-waveshare-alpha" style="display:none">
          No contributions yet &mdash; <a href="/docs/contribute">enable castor contribute on your robot</a>
        </div>
      </div>
    </div>

    <!-- unitree-go2 -->
    <div class="lb-tier-card reveal" id="tier-unitree-go2">
      <div class="lb-tier-header">
        <div class="lb-tier-name">
          <span class="lb-tier-icon">&#9679;</span>
          Unitree Go2
        </div>
        <span class="lb-tier-badge">Quadruped Tier</span>
      </div>
      <div class="lb-table-wrap">
        <table class="lb-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Robot (RRN)</th>
              <th>Score</th>
              <th>Evals</th>
              <th>Last Active</th>
            </tr>
          </thead>
          <tbody id="tbody-unitree-go2">
            <tr class="lb-loading"><td colspan="5">Loading&#8230;</td></tr>
          </tbody>
        </table>
        <div class="lb-empty" id="empty-unitree-go2" style="display:none">
          No contributions yet &mdash; <a href="/docs/contribute">enable castor contribute on your robot</a>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- ======== FOOTER CTA ======== -->
<section class="lb-cta reveal">
  <div class="container">
    <div class="lb-cta-inner">
      <h2>Want to appear here?</h2>
      <p>Add one line to your robot's config to start contributing idle compute evaluations.</p>
      <pre class="lb-code">contribute:
  enabled: true</pre>
      <a href="/docs/contribute" class="btn btn-primary">Read the docs &rarr;</a>
    </div>
  </div>
</section>

</main>

<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10/firebase-app.js';
import { getFirestore, collection, query, orderBy, limit, getDocs } from 'https://www.gstatic.com/firebasejs/10/firebase-firestore.js';

const app = initializeApp({ projectId: 'opencastor' });
const db = getFirestore(app);

const tiers = [
  'pi5-hailo8l',
  'pi5-8gb',
  'pi4-8gb',
  'server',
  'waveshare-alpha',
  'unitree-go2'
];

function relativeTime(ts) {
  if (!ts) return 'never';
  const then = ts.seconds ? ts.seconds * 1000 : Number(ts);
  const diffMs = Date.now() - then;
  const mins = Math.floor(diffMs / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return mins + 'm ago';
  const hours = Math.floor(mins / 60);
  if (hours < 24) return hours + 'h ago';
  return Math.floor(hours / 24) + 'd ago';
}

async function loadTier(tier) {
  const tbody = document.getElementById('tbody-' + tier);
  const empty = document.getElementById('empty-' + tier);
  if (!tbody || !empty) return;

  try {
    const q = query(
      collection(db, 'harness_leaderboard', tier, 'robots'),
      orderBy('score', 'desc'),
      limit(20)
    );
    const snap = await getDocs(q);

    if (snap.empty) {
      tbody.innerHTML = '';
      empty.style.display = 'block';
      return;
    }

    empty.style.display = 'none';
    let rank = 1;
    const rows = [];
    snap.forEach(function(doc) {
      const d = doc.data();
      const scoreStr = d.score != null ? (d.score * 100).toFixed(1) + '%' : '—';
      const trusted = d.trusted !== false;
      const rrn = d.rrn || doc.id;
      const untrusted = trusted ? '' : ' <span class="lb-untrusted" title="Robot not yet verified">&#9888;</span>';
      rows.push(
        '<tr>' +
        '<td class="lb-rank">' + rank + '</td>' +
        '<td class="lb-rrn">' + rrn + untrusted + '</td>' +
        '<td class="lb-score">' + scoreStr + '</td>' +
        '<td class="lb-evals">' + (d.candidates_evaluated != null ? d.candidates_evaluated : '—') + '</td>' +
        '<td class="lb-time">' + relativeTime(d.last_eval) + '</td>' +
        '</tr>'
      );
      rank++;
    });
    tbody.innerHTML = rows.join('');
  } catch (err) {
    console.warn('Leaderboard: failed to load ' + tier + ':', err);
    tbody.innerHTML = '';
    empty.style.display = 'block';
  }
}

tiers.forEach(function(tier) { loadTier(tier); });
</script>

<style>
/* ── Hero ── */
.lb-hero {
  padding: 140px 0 60px;
  text-align: center;
}
.lb-hero-inner {
  max-width: 680px;
  margin: 0 auto;
}
.lb-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: color-mix(in srgb, var(--accent) 12%, transparent);
  color: var(--accent);
  border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
  border-radius: 100px;
  padding: 5px 14px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 20px;
}
.lb-badge .dot {
  width: 6px;
  height: 6px;
  background: var(--accent);
  border-radius: 50%;
  animation: pulse-dot 2s ease-in-out infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.7); }
}
.lb-title {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 800;
  line-height: 1.1;
  color: var(--text);
  margin: 0 0 16px;
}
.lb-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0 0 28px;
}
.lb-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

/* ── Tiers ── */
.lb-tiers {
  padding: 20px 0 60px;
}
.lb-tiers .container {
  display: flex;
  flex-direction: column;
  gap: 32px;
}
.lb-tier-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.lb-tier-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 24px;
  border-bottom: 1px solid var(--border);
  background: color-mix(in srgb, var(--bg-card) 60%, var(--bg));
}
.lb-tier-name {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'Bricolage Grotesque', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  color: var(--text);
}
.lb-tier-icon {
  color: var(--accent);
  font-size: 0.5rem;
}
.lb-tier-badge {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-muted);
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 3px 10px;
}
.lb-table-wrap {
  overflow-x: auto;
}
.lb-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}
.lb-table thead th {
  padding: 10px 24px;
  text-align: left;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border);
}
.lb-table tbody tr {
  border-bottom: 1px solid color-mix(in srgb, var(--border) 50%, transparent);
  transition: background 0.15s;
}
.lb-table tbody tr:last-child {
  border-bottom: none;
}
.lb-table tbody tr:hover {
  background: color-mix(in srgb, var(--accent) 5%, transparent);
}
.lb-table td {
  padding: 12px 24px;
  color: var(--text);
  vertical-align: middle;
}
.lb-rank {
  font-weight: 700;
  color: var(--text-muted) !important;
  width: 40px;
}
.lb-table tbody tr:nth-child(1) .lb-rank { color: #f59e0b !important; }
.lb-table tbody tr:nth-child(2) .lb-rank { color: #94a3b8 !important; }
.lb-table tbody tr:nth-child(3) .lb-rank { color: #b45309 !important; }
.lb-rrn {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8rem;
  color: var(--accent) !important;
}
.lb-score {
  font-weight: 600;
}
.lb-time {
  color: var(--text-muted) !important;
  font-size: 0.82rem;
}
.lb-loading td {
  padding: 24px;
  text-align: center;
  color: var(--text-muted);
  font-size: 0.875rem;
}
.lb-untrusted {
  color: #f59e0b;
  cursor: help;
  margin-left: 4px;
}
.lb-empty {
  padding: 28px 24px;
  text-align: center;
  color: var(--text-muted);
  font-size: 0.875rem;
}
.lb-empty a {
  color: var(--accent);
  text-decoration: underline;
}

/* ── Footer CTA ── */
.lb-cta {
  padding: 60px 0 80px;
  text-align: center;
}
.lb-cta-inner {
  max-width: 480px;
  margin: 0 auto;
}
.lb-cta h2 {
  font-family: 'Bricolage Grotesque', sans-serif;
  font-size: 1.75rem;
  font-weight: 800;
  margin: 0 0 12px;
  color: var(--text);
}
.lb-cta p {
  color: var(--text-muted);
  margin: 0 0 20px;
  line-height: 1.6;
}
.lb-code {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 20px;
  text-align: left;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.875rem;
  color: var(--text);
  margin: 0 0 24px;
  white-space: pre;
}

@media (max-width: 640px) {
  .lb-hero { padding: 120px 0 40px; }
  .lb-tier-header { padding: 12px 16px; }
  .lb-table thead th,
  .lb-table td { padding: 10px 16px; }
}
</style>

</BaseLayout>
