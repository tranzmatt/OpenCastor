---
// A component that renders the featured recipes and handles client-side filtering.
---

<!-- ======== TYPE FILTER TABS ======== -->
<section class="section" style="padding-top:20px;padding-bottom:20px">
  <div class="container">
    <div class="hub-filter-bar reveal" style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px;">
      <button class="hub-filter-btn active" data-filter="all" onclick="hubFilter('all',this)">All</button>
      <button class="hub-filter-btn" data-filter="preset" onclick="hubFilter('preset',this)">🤖 Presets</button>
      <button class="hub-filter-btn" data-filter="skill" onclick="hubFilter('skill',this)">🧩 Skills</button>
      <button class="hub-filter-btn" data-filter="harness" onclick="hubFilter('harness',this)">📦 Harnesses</button>
    </div>
    <p class="hub-filter-desc" id="hub-type-desc" style="font-size:0.875rem;color:var(--text-muted);margin-bottom:24px;">
      <strong>Presets</strong> = full robot config (hardware + brain). <strong>Skills</strong> = single capabilities you can add to any robot. <strong>Harnesses</strong> = complete bundles (preset + skills + persona).
    </p>
  </div>
</section>

