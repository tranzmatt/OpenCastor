<style>
  .hub-filter-btn {
    padding: 6px 16px;
    border-radius: 20px;
    border: 1.5px solid var(--border);
    background: transparent;
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
  }
  .hub-filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .hub-filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  :root[data-theme="dark"] .hub-filter-btn.active { color: #fff; }
  .hub-filter-desc { transition: opacity 0.2s; }
</style>

<script is:inline>
  function hubFilter(type, btn) {
    // Update button states
    document.querySelectorAll('.hub-filter-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');

    // Show/hide cards
    document.querySelectorAll('[data-type]').forEach(function(card) {
      if (type === 'all' || card.dataset.type === type) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });

    // Update description
    var desc = document.getElementById('hub-type-desc');
    if (desc) {
      var descriptions = {
        all: '<strong>Presets</strong> = full robot config (hardware + brain). <strong>Skills</strong> = single capabilities you can add to any robot. <strong>Harnesses</strong> = complete bundles (preset + skills + persona).',
        preset: '<strong>Presets</strong> &#8212; complete <code>*.rcan.yaml</code> files describing a robot&#8217;s hardware + brain setup. One command to get a robot running.',
        skill: '<strong>Skills</strong> &#8212; individual capabilities you can add to any robot. Each skill teaches the robot one thing: navigate, describe, search, coordinate.',
        harness: '<strong>Harnesses</strong> &#8212; complete bundles: preset + skills + persona + eval cases. Everything to replicate a specific robot&#8217;s intelligence. Like a Docker image for robot brains.'
      };
      desc.innerHTML = descriptions[type] || descriptions.all;
    }
  }
</script>
