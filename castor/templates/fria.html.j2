<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>FRIA — {{ doc.system.robot_name }} — {{ doc.generated_at[:10] }}</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',Arial,sans-serif;font-size:14px;color:#1a1a1a;background:#fff;padding:24px}
h1{font-size:22px;font-weight:700;margin-bottom:4px}
h2{font-size:15px;font-weight:600;margin:24px 0 8px;border-bottom:1px solid #e0e0e0;padding-bottom:4px}
table{width:100%;border-collapse:collapse;margin-bottom:12px}
th,td{text-align:left;padding:6px 10px;border:1px solid #e0e0e0;font-size:13px}
th{background:#f5f5f5;font-weight:600}
.pass{color:#1a7a3a;font-weight:600}
.warn{color:#b45309;font-weight:600}
.fail{color:#b91c1c;font-weight:600}
.badge{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600}
.badge-pass{background:#dcfce7;color:#166534}
.badge-warn{background:#fef9c3;color:#854d0e}
.badge-fail{background:#fee2e2;color:#991b1b}
.cover{border-bottom:2px solid #1a1a1a;padding-bottom:20px;margin-bottom:24px}
.subtitle{color:#555;font-size:13px;margin-top:4px}
.waived-banner{background:#fef9c3;border:1px solid #d97706;padding:8px 12px;border-radius:4px;margin:8px 0;font-size:13px}
.score{font-size:28px;font-weight:700}
.score-row{display:flex;gap:24px;align-items:center;margin:8px 0}
.score-label{font-size:12px;color:#666}
footer{margin-top:32px;padding-top:12px;border-top:1px solid #e0e0e0;font-size:11px;color:#888}
.check-id{font-family:monospace;font-size:12px}
.bool-yes{color:#1a7a3a;font-weight:600}
.bool-no{color:#b91c1c;font-weight:600}
@media print{body{padding:0} .no-print{display:none}}
</style>
</head>
<body>

<!-- Cover -->
<div class="cover">
  <h1>Fundamental Rights Impact Assessment</h1>
  <div class="subtitle">
    Generated by OpenCastor {{ doc.system.opencastor_version }} &middot;
    <a href="{{ doc.spec_ref }}">{{ doc.spec_ref }}</a>
  </div>
  {% if doc.deployment.prerequisite_waived %}
  <div class="waived-banner">
    &#9888; Prerequisite waived (--force): conformance gate was bypassed during generation.
    This document may not satisfy L2+ conformance requirements.
  </div>
  {% endif %}
</div>

<!-- System Identity -->
<h2>System Identity</h2>
<table>
  <tr><th>Field</th><th>Value</th></tr>
  <tr><td>RRN</td><td>{{ doc.system.rrn }}</td></tr>
  <tr><td>RRN URI</td><td>{{ doc.system.rrn_uri or '&mdash;' }}</td></tr>
  <tr><td>Robot Name</td><td>{{ doc.system.robot_name }}</td></tr>
  <tr><td>OpenCastor Version</td><td>{{ doc.system.opencastor_version }}</td></tr>
  <tr><td>RCAN Version</td><td>{{ doc.system.rcan_version }}</td></tr>
  <tr><td>AI Provider</td><td>{{ doc.system.agent_provider }}</td></tr>
  <tr><td>AI Model</td><td>{{ doc.system.agent_model }}</td></tr>
  <tr><td>Generated At</td><td>{{ doc.generated_at }}</td></tr>
</table>

<!-- Deployment Classification -->
<h2>Deployment Classification (EU AI Act Annex III)</h2>
<table>
  <tr><th>Field</th><th>Value</th></tr>
  <tr><td>Annex III Basis</td><td><strong>{{ doc.deployment.annex_iii_basis }}</strong></td></tr>
  <tr><td>Intended Use</td><td>{{ doc.deployment.intended_use }}</td></tr>
  <tr><td>Prerequisite Waived</td><td>{{ 'Yes (--force)' if doc.deployment.prerequisite_waived else 'No' }}</td></tr>
</table>

<!-- Conformance Evidence -->
<h2>Conformance Evidence (Art. 9 Risk Management)</h2>
<div class="score-row">
  <div>
    <div class="score">{{ doc.conformance.score }}/100</div>
    <div class="score-label">Conformance Score</div>
  </div>
  <div>
    <span class="badge badge-pass">{{ doc.conformance.pass }} pass</span>
    <span class="badge badge-warn">{{ doc.conformance.warn }} warn</span>
    <span class="badge badge-fail">{{ doc.conformance.fail }} fail</span>
  </div>
</div>
<table>
  <tr><th>Check ID</th><th>Category</th><th>Status</th><th>Detail</th></tr>
  {% for check in doc.conformance.checks %}
  <tr>
    <td class="check-id">{{ check.check_id }}</td>
    <td>{{ check.category }}</td>
    <td><span class="badge badge-{{ check.status }}">{{ check.status }}</span></td>
    <td>{{ check.detail }}{% if 'fix' in check %} <em style="color:#666">Fix: {{ check.fix }}</em>{% endif %}</td>
  </tr>
  {% endfor %}
</table>

<!-- Human Oversight -->
<h2>Human Oversight Configuration (Art. 14)</h2>
<table>
  <tr><th>Control</th><th>Configured</th></tr>
  <tr>
    <td>Human-in-the-Loop (HiTL) Gates</td>
    <td class="{{ 'bool-yes' if doc.human_oversight.hitl_configured else 'bool-no' }}">
      {{ 'Yes' if doc.human_oversight.hitl_configured else 'No' }}
    </td>
  </tr>
  <tr>
    <td>Confidence Gates</td>
    <td class="{{ 'bool-yes' if doc.human_oversight.confidence_gates_configured else 'bool-no' }}">
      {{ 'Yes' if doc.human_oversight.confidence_gates_configured else 'No' }}
    </td>
  </tr>
  <tr>
    <td>Emergency Stop (ESTOP)</td>
    <td class="{{ 'bool-yes' if doc.human_oversight.estop_configured else 'bool-no' }}">
      {{ 'Yes' if doc.human_oversight.estop_configured else 'No' }}
    </td>
  </tr>
</table>

<!-- Hardware Observations -->
<h2>Hardware Observations (Art. 17 Quality Management)</h2>
{% if doc.hardware_observations %}
<table>
  <tr><th>ID</th><th>Observation</th><th>Confidence</th><th>Tags</th></tr>
  {% for obs in doc.hardware_observations %}
  <tr>
    <td class="check-id">{{ obs.id }}</td>
    <td>{{ obs.text }}</td>
    <td>{{ "%.0f"|format(obs.confidence * 100) }}%</td>
    <td>{{ obs.tags | join(', ') if obs.tags else '&mdash;' }}</td>
  </tr>
  {% endfor %}
</table>
{% else %}
<p style="color:#666;font-size:13px">No hardware observations recorded in robot memory.</p>
{% endif %}

<!-- Signing Key -->
{% if 'signing_key' in doc %}
<h2>Document Signature (Art. 27 FRIA)</h2>
<table>
  <tr><th>Field</th><th>Value</th></tr>
  <tr><td>Algorithm</td><td>{{ doc.signing_key.alg }}</td></tr>
  <tr><td>Key ID</td><td><code>{{ doc.signing_key.kid }}</code></td></tr>
  <tr><td>Public Key (truncated)</td><td><code>{{ doc.signing_key.public_key[:40] }}&hellip;</code></td></tr>
  {% if 'sig' in doc %}
  <tr><td>Signature (truncated)</td><td><code>{{ doc.sig.value[:40] }}&hellip;</code></td></tr>
  {% endif %}
</table>
{% endif %}

<!-- Footer -->
<footer>
  Generated by OpenCastor {{ doc.system.opencastor_version }} &middot;
  Specification: <a href="{{ doc.spec_ref }}">{{ doc.spec_ref }}</a> &middot;
  EU AI Act Art.&nbsp;9, Art.&nbsp;14, Art.&nbsp;17, Art.&nbsp;27, Annex&nbsp;III, Annex&nbsp;IV
</footer>

</body>
</html>
