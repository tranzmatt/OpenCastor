# OpenCastor Swarm — node registry
# Each entry is a Castor gateway node reachable on the local network.
# Use `castor status --swarm` to query all nodes at once.
#
# Fields:
#   name:     Human-readable robot name
#   host:     Hostname or IP
#   port:     Gateway port (default 8000)
#   token:    OPENCASTOR_API_TOKEN for that node
#   rcan:     Path to the node's .rcan.yaml (if local clone is available)
#   tags:     Free-form labels for filtering (e.g. camera, arm, rover)

nodes:
  - name: alex
    host: alex.local
    ip: 192.168.x.x
    port: 8000
    token: REPLACE_WITH_OPENCASTOR_API_TOKEN_FOR_THIS_NODE
    rcan: ~/OpenCastor/alex.rcan.yaml
    tags: [rpi5, camera, i2c, rover]
    added: "2026-02-21"
  - name: bob
    host: bob.local
    ip: 192.168.x.x
    port: 8001
    token: REPLACE_WITH_OPENCASTOR_API_TOKEN_FOR_THIS_NODE
    rcan: ~/OpenCastor/bob.rcan.yaml
    tags: [dev, local, dashboard]
    added: "2026-02-22"
